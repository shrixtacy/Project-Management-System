{
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "/api/index" },
    { "source": "/api/upload/:path*", "destination": "/api/index" },
    { "source": "/api/health", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
